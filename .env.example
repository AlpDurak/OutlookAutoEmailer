# Credentials and configuration for the application. Make sure to replace the placeholder values with your actual credentials and settings.
# Get these from: https://portal.azure.com -> App registrations
AZURE_CLIENT_ID=your-azure-client-id-here
AZURE_TENANT_ID=your-azure-tenant-id-here
IMGBB_API_KEY=your_imgbb_key_here
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# SMTP Configuration (Office 365 by default)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_STARTTLS_ENABLED=true

# Rate Limiting
RATE_LIMIT_EMAILS_PER_HOUR=100
RATE_LIMIT_DELAY_MIN_MS=3000
RATE_LIMIT_DELAY_MAX_MS=8000

# Retry Policy
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_MULTIPLIER=2

# Logging
LOGGING_LEVEL=INFO
