<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.outlookautoemailier</groupId>
    <artifactId>OutlookAutoEmailer</artifactId>
    <version>1.2.0</version>
    <packaging>jar</packaging>

    <properties>
        <maven.compiler.source>17</maven.compiler.source>
        <maven.compiler.target>17</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <javafx.version>21.0.2</javafx.version>
    </properties>

    <dependencies>
        <!-- JavaFX -->
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-controls</artifactId>
            <version>${javafx.version}</version>
        </dependency>
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-fxml</artifactId>
            <version>${javafx.version}</version>
        </dependency>
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-web</artifactId>
            <version>${javafx.version}</version>
        </dependency>

        <!-- Microsoft Graph SDK -->
        <dependency>
            <groupId>com.microsoft.graph</groupId>
            <artifactId>microsoft-graph</artifactId>
            <version>5.77.0</version>
        </dependency>

        <!-- MSAL4J for OAuth2 -->
        <dependency>
            <groupId>com.microsoft.azure</groupId>
            <artifactId>msal4j</artifactId>
            <version>1.15.1</version>
        </dependency>

        <!-- Jakarta Mail -->
        <dependency>
            <groupId>com.sun.mail</groupId>
            <artifactId>jakarta.mail</artifactId>
            <version>2.0.1</version>
        </dependency>

        <!-- SLF4J API -->
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-api</artifactId>
            <version>2.0.9</version>
        </dependency>

        <!-- Logback -->
        <dependency>
            <groupId>ch.qos.logback</groupId>
            <artifactId>logback-classic</artifactId>
            <version>1.4.14</version>
        </dependency>

        <!-- Jackson for JSON template serialisation -->
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
            <version>2.16.1</version>
        </dependency>

        <!-- JUnit 5 -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <version>5.10.1</version>
            <scope>test</scope>
        </dependency>

        <!-- Jsoup HTML parser (CSS inlining for email) -->
        <dependency>
            <groupId>org.jsoup</groupId>
            <artifactId>jsoup</artifactId>
            <version>1.17.2</version>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <!-- JavaFX Maven Plugin -->
            <plugin>
                <groupId>org.openjfx</groupId>
                <artifactId>javafx-maven-plugin</artifactId>
                <version>0.0.8</version>
                <configuration>
                    <mainClass>com.outlookautoemailier.Main</mainClass>
                </configuration>
            </plugin>
            <!-- Maven Surefire for JUnit 5 -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.2.3</version>
            </plugin>
        </plugins>
    </build>

    <!-- ═══ EXE packaging profile: mvn clean package -Ppackage-exe -DskipTests ═══ -->
    <!--     Output: target\installer\OutlookAutoEmailer-1.2.0.exe                  -->
    <profiles>
        <profile>
            <id>package-exe</id>

            <!-- Windows-native JavaFX JARs (contain .dll natives required at runtime) -->
            <dependencies>
                <dependency>
                    <groupId>org.openjfx</groupId><artifactId>javafx-base</artifactId>
                    <version>${javafx.version}</version><classifier>win</classifier>
                </dependency>
                <dependency>
                    <groupId>org.openjfx</groupId><artifactId>javafx-graphics</artifactId>
                    <version>${javafx.version}</version><classifier>win</classifier>
                </dependency>
                <dependency>
                    <groupId>org.openjfx</groupId><artifactId>javafx-controls</artifactId>
                    <version>${javafx.version}</version><classifier>win</classifier>
                </dependency>
                <dependency>
                    <groupId>org.openjfx</groupId><artifactId>javafx-fxml</artifactId>
                    <version>${javafx.version}</version><classifier>win</classifier>
                </dependency>
                <dependency>
                    <groupId>org.openjfx</groupId><artifactId>javafx-web</artifactId>
                    <version>${javafx.version}</version><classifier>win</classifier>
                </dependency>
                <dependency>
                    <groupId>org.openjfx</groupId><artifactId>javafx-media</artifactId>
                    <version>${javafx.version}</version><classifier>win</classifier>
                </dependency>
            </dependencies>

            <build>
                <plugins>

                    <!-- Step 1 (prepare-package): copy all runtime deps into target/libs/
                         Two executions: (a) everything except org.openjfx, then
                         (b) only the Windows-native JavaFX JARs (classifier=win).
                         This prevents duplicate module errors at runtime — the plain
                         javafx-base-21.0.2.jar and javafx-base-21.0.2-win.jar both
                         declare module javafx.base, which causes an immediate JVM crash. -->
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-dependency-plugin</artifactId>
                        <version>3.6.1</version>
                        <executions>
                            <!-- (a) All runtime deps except JavaFX -->
                            <execution>
                                <id>copy-deps</id>
                                <phase>prepare-package</phase>
                                <goals><goal>copy-dependencies</goal></goals>
                                <configuration>
                                    <outputDirectory>${project.build.directory}/libs</outputDirectory>
                                    <includeScope>runtime</includeScope>
                                    <excludeGroupIds>org.openjfx</excludeGroupIds>
                                </configuration>
                            </execution>
                            <!-- (b) Windows-native JavaFX JARs only (contain .dll natives) -->
                            <execution>
                                <id>copy-javafx-win</id>
                                <phase>prepare-package</phase>
                                <goals><goal>copy-dependencies</goal></goals>
                                <configuration>
                                    <outputDirectory>${project.build.directory}/libs</outputDirectory>
                                    <includeScope>runtime</includeScope>
                                    <includeGroupIds>org.openjfx</includeGroupIds>
                                    <includeClassifiers>win</includeClassifiers>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>

                    <!-- Step 2 (package): write the app JAR directly into target/libs/
                         so jpackage finds everything in one place -->
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-jar-plugin</artifactId>
                        <version>3.3.0</version>
                        <configuration>
                            <outputDirectory>${project.build.directory}/libs</outputDirectory>
                        </configuration>
                    </plugin>

                    <!-- Step 3 (package): bundle into a self-contained Windows EXE
                         (jpackage embeds a JRE — no Java installation required on target PC) -->
                    <plugin>
                        <groupId>org.panteleyev</groupId>
                        <artifactId>jpackage-maven-plugin</artifactId>
                        <version>1.6.5</version>
                        <configuration>
                            <name>OutlookAutoEmailer</name>
                            <appVersion>1.2.0</appVersion>
                            <vendor>OutlookAutoEmailer</vendor>
                            <destination>${project.build.directory}/installer</destination>
                            <!-- All JARs (app + deps + JavaFX natives) live here -->
                            <input>${project.build.directory}/libs</input>
                            <mainJar>${project.build.finalName}.jar</mainJar>
                            <mainClass>com.outlookautoemailier.Main</mainClass>
                            <!-- Load JavaFX modules at runtime from the install dir -->
                            <javaOptions>
                                <option>--module-path $APPDIR</option>
                                <option>--add-modules javafx.base,javafx.graphics,javafx.controls,javafx.fxml,javafx.web,javafx.media</option>
                                <option>--add-opens=javafx.graphics/com.sun.javafx.application=ALL-UNNAMED</option>
                                <option>--add-opens=java.base/java.lang=ALL-UNNAMED</option>
                                <option>--add-opens=java.base/java.lang.reflect=ALL-UNNAMED</option>
                            </javaOptions>
                            <!-- app-image: no WiX required; produces a self-contained folder
                                 with OutlookAutoEmailer.exe inside target/installer/OutlookAutoEmailer/ -->
                            <type>APP_IMAGE</type>
                        </configuration>
                        <executions>
                            <execution>
                                <id>jpackage</id>
                                <phase>package</phase>
                                <goals><goal>jpackage</goal></goals>
                            </execution>
                        </executions>
                    </plugin>

                </plugins>
            </build>
        </profile>
    </profiles>
</project>
