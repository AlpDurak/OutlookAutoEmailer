<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox spacing="0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.outlookautoemailier.ui.AnalyticsController">

    <padding>
        <Insets top="28" right="28" bottom="24" left="28"/>
    </padding>

    <!-- ── Page heading ─────────────────────────────────────────────────── -->
    <VBox spacing="4">
        <Label text="Email Analytics" styleClass="page-title"/>
        <Label text="Campaign performance and delivery statistics."
               styleClass="help-label"/>
    </VBox>

    <Region prefHeight="20"/>
    <Separator/>
    <Region prefHeight="20"/>

    <!-- ── Primary stat cards ───────────────────────────────────────────── -->
    <HBox spacing="12">
        <VBox styleClass="stat-card" alignment="CENTER" minWidth="160">
            <Label fx:id="healthScoreLabel" text="--" styleClass="stat-count"/>
            <Label fx:id="healthScoreTierLabel" text="Health Score" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card" alignment="CENTER" minWidth="120">
            <Label fx:id="totalSentLabel" text="0" styleClass="stat-count"
                   style="-fx-text-fill:#2563eb;"/>
            <Label text="Emails Sent" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card" alignment="CENTER" minWidth="120">
            <Label fx:id="totalDeliveredLabel" text="0" styleClass="stat-count"
                   style="-fx-text-fill:#16a34a;"/>
            <Label text="Delivered" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card" alignment="CENTER" minWidth="120">
            <Label fx:id="totalBatchesLabel" text="0" styleClass="stat-count"/>
            <Label text="Campaigns" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card" alignment="CENTER" minWidth="120">
            <Label fx:id="avgOpenRateLabel" text="0.0%" styleClass="stat-count"/>
            <Label text="Avg Unique Open Rate" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card" alignment="CENTER" minWidth="120">
            <Label fx:id="avgCtorLabel" text="0.0%" styleClass="stat-count"
                   style="-fx-text-fill:#0d9488;"/>
            <Label text="Avg CTOR" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card" alignment="CENTER" minWidth="120">
            <Label fx:id="totalFailedLabel" text="0" styleClass="stat-count"
                   style="-fx-text-fill:#dc2626;"/>
            <Label text="Failed Sends" styleClass="stat-label"/>
        </VBox>
    </HBox>

    <Region prefHeight="12"/>

    <!-- ── Suppression stat cards ────────────────────────────────────────── -->
    <HBox spacing="12">
        <VBox styleClass="stat-card" alignment="CENTER" minWidth="120">
            <Label fx:id="totalSuppressedLabel" text="0" styleClass="stat-count"/>
            <Label text="Total Suppressed" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card" alignment="CENTER" minWidth="130">
            <Label fx:id="suppressedThisMonthLabel" text="0" styleClass="stat-count"
                   style="-fx-text-fill:#d97706;"/>
            <Label text="Suppressed This Month" styleClass="stat-label"/>
        </VBox>
    </HBox>

    <Region prefHeight="12"/>

    <!-- ── Reachability stat cards ──────────────────────────────────────── -->
    <HBox spacing="12">
        <VBox styleClass="stat-card" alignment="CENTER" minWidth="140">
            <Label fx:id="reachableCountLabel" text="0"
                   styleClass="stat-count,stat-count-reachable"/>
            <Label text="Reachable" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card" alignment="CENTER" minWidth="140">
            <Label fx:id="atRiskCountLabel" text="0"
                   styleClass="stat-count,stat-count-at-risk"/>
            <Label text="At Risk" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card" alignment="CENTER" minWidth="140">
            <Label fx:id="unreachableCountLabel" text="0"
                   styleClass="stat-count,stat-count-unreachable"/>
            <Label text="Unreachable" styleClass="stat-label"/>
        </VBox>
    </HBox>

    <Region prefHeight="12"/>

    <!-- ── Engagement tier cards ─────────────────────────────────────────── -->
    <Label text="RECIPIENT ENGAGEMENT TIERS" styleClass="section-header"/>
    <Region prefHeight="4"/>
    <HBox spacing="12">
        <VBox styleClass="stat-card" alignment="CENTER" minWidth="130">
            <Label fx:id="championsCountLabel" text="0" styleClass="stat-count"
                   style="-fx-text-fill:#16a34a;"/>
            <Label text="Champions" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card" alignment="CENTER" minWidth="130">
            <Label fx:id="activeCountLabel" text="0" styleClass="stat-count"
                   style="-fx-text-fill:#0d9488;"/>
            <Label text="Active" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card" alignment="CENTER" minWidth="130">
            <Label fx:id="atRiskEngagementLabel" text="0" styleClass="stat-count"
                   style="-fx-text-fill:#d97706;"/>
            <Label text="At-Risk" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card" alignment="CENTER" minWidth="130">
            <Label fx:id="dormantCountLabel" text="0" styleClass="stat-count"
                   style="-fx-text-fill:#dc2626;"/>
            <Label text="Dormant" styleClass="stat-label"/>
        </VBox>
    </HBox>

    <Region prefHeight="16"/>

    <!-- ── Toolbar ──────────────────────────────────────────────────────── -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="aiInsightsButton" text="AI Insights" onAction="#onAiInsights"
                styleClass="ai-toggle-btn">
            <graphic><FontIcon iconLiteral="fas-magic" iconSize="14" style="-fx-icon-color: #ffffff;"/></graphic>
        </Button>
        <ProgressIndicator fx:id="aiSpinner" prefWidth="20" prefHeight="20"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Subject Analysis" onAction="#onSubjectAnalysis" styleClass="secondary-button">
            <graphic><FontIcon iconLiteral="fas-heading" iconSize="14"/></graphic>
        </Button>
        <Button text="Link Leaderboard" onAction="#onLinkLeaderboard" styleClass="secondary-button">
            <graphic><FontIcon iconLiteral="fas-link" iconSize="14"/></graphic>
        </Button>
        <Button text="Sync Opens" onAction="#onSyncOpens" styleClass="secondary-button">
            <graphic><FontIcon iconLiteral="fas-sync-alt" iconSize="14"/></graphic>
        </Button>
        <Button text="Refresh" onAction="#onRefresh" styleClass="secondary-button">
            <graphic><FontIcon iconLiteral="fas-sync-alt" iconSize="14"/></graphic>
        </Button>
    </HBox>

    <Region prefHeight="12"/>

    <!-- ── AI Insights panel ────────────────────────────────────────────── -->
    <VBox fx:id="aiInsightsPanel" styleClass="ai-insights-panel" spacing="8">
        <TextArea fx:id="aiInsightsArea" prefRowCount="12" editable="false"
                  wrapText="true"
                  promptText="AI-generated campaign insights will appear here..."/>
    </VBox>

    <Region prefHeight="16"/>

    <!-- ── Campaign batch table ─────────────────────────────────────────── -->
    <Label text="CAMPAIGNS" styleClass="section-header"/>
    <Region prefHeight="8"/>
    <TableView fx:id="batchTable" prefHeight="260">
        <columns>
            <TableColumn fx:id="batchNameColumn"      text="Campaign"   prefWidth="150"/>
            <TableColumn fx:id="batchSubjectColumn"   text="Subject"    prefWidth="170"/>
            <TableColumn fx:id="batchSentAtColumn"    text="Sent At"    prefWidth="130"/>
            <TableColumn fx:id="batchTotalColumn"     text="Total"      prefWidth="50"/>
            <TableColumn fx:id="batchSentColumn"      text="Delivered"  prefWidth="65"/>
            <TableColumn fx:id="batchFailedColumn"    text="Failed"     prefWidth="50"/>
            <TableColumn fx:id="batchOpensColumn"     text="Uniq.Opens" prefWidth="72"/>
            <TableColumn fx:id="batchOpenRateColumn"  text="Open Rate"  prefWidth="72"/>
            <TableColumn fx:id="batchCtorColumn"      text="CTOR"       prefWidth="62"/>
            <TableColumn fx:id="batchUnsubRateColumn" text="Unsub Rate" prefWidth="75"/>
        </columns>
        <placeholder>
            <Label text="No campaigns sent yet." styleClass="help-label"/>
        </placeholder>
    </TableView>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Region prefHeight="8"/>
        <Button text="View Campaign Details" onAction="#onViewDetails">
            <graphic><FontIcon iconLiteral="fas-eye" iconSize="14"/></graphic>
        </Button>
    </HBox>

    <Separator>
        <VBox.margin><Insets top="16" bottom="16"/></VBox.margin>
    </Separator>

    <!-- ── ECharts: campaign open/click rates ───────────────────────────── -->
    <Label text="CAMPAIGN PERFORMANCE" styleClass="section-header"/>
    <Region prefHeight="8"/>
    <WebView fx:id="chartView" prefHeight="240" VBox.vgrow="NEVER"/>

    <Separator>
        <VBox.margin><Insets top="16" bottom="16"/></VBox.margin>
    </Separator>

    <!-- ── Hourly distribution ──────────────────────────────────────────── -->
    <Label text="HOURLY SEND DISTRIBUTION" styleClass="section-header"/>
    <Region prefHeight="8"/>
    <WebView fx:id="hourlyChartView" prefHeight="260" VBox.vgrow="NEVER"/>
    <Label fx:id="sendTimeAdvice" text="" styleClass="advice-label"/>

    <Separator>
        <VBox.margin><Insets top="16" bottom="16"/></VBox.margin>
    </Separator>

    <!-- ── Weekly unsubscribe trend ─────────────────────────────────────── -->
    <Label text="WEEKLY UNSUBSCRIBE TREND" styleClass="section-header"/>
    <Region prefHeight="8"/>
    <WebView fx:id="unsubChartView" prefHeight="240" VBox.vgrow="NEVER"/>

</VBox>
