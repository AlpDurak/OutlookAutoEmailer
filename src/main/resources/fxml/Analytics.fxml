<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.web.WebView?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.outlookautoemailier.ui.AnalyticsController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Email Analytics" styleClass="page-title"/>

    <!-- ── Summary stat cards ──────────────────────────────────────────────── -->
    <HBox spacing="16">
        <VBox styleClass="stat-card" alignment="CENTER" minWidth="130">
            <Label fx:id="totalBatchesLabel" text="0" styleClass="stat-count"/>
            <Label text="Campaigns" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card" alignment="CENTER" minWidth="130">
            <Label fx:id="avgOpenRateLabel" text="0.0%" styleClass="stat-count"/>
            <Label text="Avg Open Rate" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card" alignment="CENTER" minWidth="130">
            <Label fx:id="totalSentLabel" text="0" styleClass="stat-count"/>
            <Label text="Emails Sent" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card" alignment="CENTER" minWidth="130">
            <Label fx:id="totalFailedLabel" text="0" styleClass="stat-count"
                   style="-fx-text-fill:#ef4444;"/>
            <Label text="Failed Sends" styleClass="stat-label"/>
        </VBox>
    </HBox>

    <!-- ── Toolbar ─────────────────────────────────────────────────────────── -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Sync Opens" onAction="#onSyncOpens"/>
        <Button text="Refresh"    onAction="#onRefresh"/>
    </HBox>

    <!-- ── Campaign batch table ────────────────────────────────────────────── -->
    <TableView fx:id="batchTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="batchNameColumn"     text="Campaign"  prefWidth="160"/>
            <TableColumn fx:id="batchSubjectColumn"  text="Subject"   prefWidth="200"/>
            <TableColumn fx:id="batchSentAtColumn"   text="Sent At"   prefWidth="140"/>
            <TableColumn fx:id="batchTotalColumn"    text="Total"     prefWidth="60"/>
            <TableColumn fx:id="batchSentColumn"     text="Delivered" prefWidth="75"/>
            <TableColumn fx:id="batchFailedColumn"   text="Failed"    prefWidth="60"/>
            <TableColumn fx:id="batchOpensColumn"    text="Opens"     prefWidth="60"/>
            <TableColumn fx:id="batchOpenRateColumn" text="Open Rate" prefWidth="80"/>
        </columns>
        <placeholder>
            <Label text="No campaigns sent yet."/>
        </placeholder>
    </TableView>

    <!-- ── Detail button ───────────────────────────────────────────────────── -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="View Campaign Details" onAction="#onViewDetails"/>
    </HBox>

    <Separator/>

    <!-- ── ECharts panel (campaign open/click rates) ───────────────────────── -->
    <WebView fx:id="chartView" prefHeight="240" VBox.vgrow="NEVER"/>

    <Separator/>

    <!-- ── Hourly distribution chart (send count + success rate overlay) ─── -->
    <Label text="Hourly Send Distribution" styleClass="section-title"/>
    <WebView fx:id="hourlyChartView" prefHeight="260" VBox.vgrow="NEVER"/>
    <Label fx:id="sendTimeAdvice" text="" styleClass="advice-label"/>

</VBox>
