<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox spacing="0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.outlookautoemailier.ui.AccountSetupController">

    <padding>
        <Insets top="32" right="32" bottom="32" left="32"/>
    </padding>

    <!-- ── Page heading ─────────────────────────────────────────────────── -->
    <VBox spacing="4">
        <Label text="Account Setup" styleClass="page-title"/>
        <Label text="Connect your Microsoft 365 accounts to get started."
               styleClass="help-label"/>
    </VBox>

    <Region prefHeight="20"/>
    <Separator/>
    <Region prefHeight="24"/>

    <!-- ── Two account cards side-by-side ───────────────────────────────── -->
    <HBox spacing="20" fillHeight="true">

        <!-- Source Account card -->
        <VBox styleClass="account-card" HBox.hgrow="ALWAYS">

            <HBox styleClass="account-card-header" alignment="CENTER_LEFT" spacing="10">
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label text="Source Account" styleClass="account-card-title"/>
                    <Label text="Reads contacts from your Outlook directory"
                           styleClass="help-label"/>
                </VBox>
                <Label fx:id="sourceStatusLabel" text="Not connected"
                       styleClass="status-disconnected"/>
            </HBox>

            <VBox styleClass="account-card-body" spacing="16">
                <Region prefHeight="4"/>
                <Label fx:id="sourceEmailLabel" text=""
                       style="-fx-font-size:12px; -fx-text-fill:#1d4ed8; -fx-font-weight:bold;"
                       wrapText="true"/>
                <Button fx:id="btnConnectSource"
                        text="Connect via Microsoft OAuth"
                        onAction="#onConnectSource"
                        styleClass="primary-button"
                        maxWidth="Infinity">
                    <graphic><FontIcon iconLiteral="fas-sign-in-alt" iconSize="14"/></graphic>
                </Button>
            </VBox>
        </VBox>

        <!-- Sender Account card -->
        <VBox styleClass="account-card" HBox.hgrow="ALWAYS">

            <HBox styleClass="account-card-header" alignment="CENTER_LEFT" spacing="10">
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label text="Sender Account" styleClass="account-card-title"/>
                    <Label text="Sends emails via SMTP on your behalf"
                           styleClass="help-label"/>
                </VBox>
                <Label fx:id="senderStatusLabel" text="Not connected"
                       styleClass="status-disconnected"/>
            </HBox>

            <VBox styleClass="account-card-body" spacing="16">
                <Region prefHeight="4"/>

                <!-- Provider selector -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Provider:" style="-fx-min-width:70px; -fx-font-weight:bold;"/>
                    <ChoiceBox fx:id="senderProviderChoice" prefWidth="200"/>
                </HBox>

                <Label fx:id="gmailHintLabel"
                       text="Gmail: enter your Google Client ID and Secret in Settings first."
                       wrapText="true" styleClass="help-label" managed="false" visible="false"/>

                <Label fx:id="senderEmailLabel" text=""
                       style="-fx-font-size:12px; -fx-text-fill:#1d4ed8; -fx-font-weight:bold;"
                       wrapText="true"/>

                <Button fx:id="btnConnectSender"
                        text="Connect Sender Account"
                        onAction="#onConnectSender"
                        styleClass="primary-button"
                        maxWidth="Infinity">
                    <graphic><FontIcon iconLiteral="fas-sign-in-alt" iconSize="14"/></graphic>
                </Button>
            </VBox>
        </VBox>

    </HBox>
</VBox>
