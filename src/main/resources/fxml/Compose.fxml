<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<VBox spacing="15"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.outlookautoemailier.ui.ComposeController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- ── Page title ──────────────────────────────────────────────────────── -->
    <Label text="Compose Email" styleClass="page-title"/>

    <!-- ── Template toolbar ────────────────────────────────────────────────── -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Template Name:"/>
        <TextField fx:id="templateNameField"
                   promptText="My Template"
                   prefWidth="180"/>
        <Button text="Save Template" onAction="#onSaveTemplate"/>
        <Button text="Load Template" onAction="#onLoadTemplate"/>
    </HBox>

    <!-- ── Campaign name ───────────────────────────────────────────────────── -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Campaign Name:"/>
        <TextField fx:id="campaignNameField"
                   promptText="e.g. March Newsletter 2026"
                   prefWidth="250"/>
    </HBox>

    <!-- ── Group quick-select ────────────────────────────────────────────────── -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Send to Group:"/>
        <ComboBox fx:id="groupComboBox"
                  promptText="Select a group (optional)"
                  prefWidth="220"
                  onAction="#onGroupSelected"/>
        <Label text="(selecting a group replaces current recipients)"
               styleClass="help-label"/>
    </HBox>

    <Separator/>

    <!-- ── Subject row ─────────────────────────────────────────────────────── -->
    <Label text="Subject:" style="-fx-font-weight:bold; -fx-text-fill:#374151;"/>
    <HBox spacing="6" alignment="CENTER_LEFT">
        <TextField fx:id="subjectField"
                   promptText="Enter email subject…"
                   HBox.hgrow="ALWAYS"/>
        <!-- Variable-insertion buttons targeting the subject field -->
        <Button text="{{firstName}}" onAction="#onInsertVariable" userData="subject" styleClass="tag-btn"/>
        <Button text="{{lastName}}"  onAction="#onInsertVariable" userData="subject" styleClass="tag-btn"/>
        <Button text="{{email}}"     onAction="#onInsertVariable" userData="subject" styleClass="tag-btn"/>
        <Button text="{{company}}"   onAction="#onInsertVariable" userData="subject" styleClass="tag-btn"/>
    </HBox>

    <!-- ── Body area ───────────────────────────────────────────────────────── -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Message Body:"/>
        <javafx.scene.layout.Region HBox.hgrow="ALWAYS"/>
        <ToggleButton fx:id="htmlModeToggle"
                      text="HTML Mode"
                      onAction="#onToggleHtmlMode"/>
    </HBox>
    <TextArea fx:id="bodyArea"
              prefRowCount="15"
              wrapText="true"
              promptText="Write your email body here. Use the buttons below to insert personalization variables."
              VBox.vgrow="ALWAYS"/>

    <!-- ── HTML preview (shown only in HTML mode) ──────────────────────────── -->
    <WebView fx:id="htmlPreview"
             prefHeight="200"
             visible="false"
             managed="false"
             VBox.vgrow="SOMETIMES"/>

    <!-- Variable-insertion buttons targeting the body area -->
    <HBox spacing="6">
        <Button text="{{firstName}}" onAction="#onInsertVariable" userData="body" styleClass="tag-btn"/>
        <Button text="{{lastName}}"  onAction="#onInsertVariable" userData="body" styleClass="tag-btn"/>
        <Button text="{{email}}"     onAction="#onInsertVariable" userData="body" styleClass="tag-btn"/>
        <Button text="{{company}}"   onAction="#onInsertVariable" userData="body" styleClass="tag-btn"/>
    </HBox>

    <Separator/>

    <!-- ── Schedule controls ───────────────────────────────────────────────── -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <CheckBox fx:id="scheduleCheckbox" text="Schedule for later" onAction="#onScheduleToggle"/>
    </HBox>
    <HBox fx:id="scheduleControls" spacing="10" alignment="CENTER_LEFT"
          visible="false" managed="false">
        <Label text="Date:"/>
        <DatePicker fx:id="scheduleDatePicker" prefWidth="150"/>
        <Label text="Hour:"/>
        <Spinner fx:id="scheduleHourSpinner" prefWidth="75"/>
        <Label text="Min:"/>
        <Spinner fx:id="scheduleMinuteSpinner" prefWidth="75"/>
        <Label fx:id="schedulePreviewLabel" styleClass="help-label"/>
    </HBox>

    <!-- ── Footer: recipient count + actions ───────────────────────────────── -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label fx:id="recipientCountLabel" text="0 recipients selected"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Preview"      onAction="#onPreview"/>
        <Button fx:id="sendButton" text="Send Emails"
                styleClass="primary-button"
                onAction="#onSendEmails"/>
    </HBox>

</VBox>
