<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.outlookautoemailier.ui.ContactListController">

    <StackPane AnchorPane.topAnchor="0"
               AnchorPane.rightAnchor="0"
               AnchorPane.bottomAnchor="0"
               AnchorPane.leftAnchor="0">

        <VBox spacing="10">

        <padding>
            <Insets top="20" right="20" bottom="10" left="20"/>
        </padding>

        <!-- ── Row 1: title + search + refresh ──────────────────────────── -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Contacts" styleClass="page-title" HBox.hgrow="NEVER"/>
            <javafx.scene.layout.Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="searchField"
                       promptText="Search contacts..."
                       prefWidth="200"/>
            <Button text="Refresh" onAction="#onRefresh"/>
        </HBox>

        <!-- ── Filter panel ──────────────────────────────────────────────── -->
        <TitledPane fx:id="filterPane" text="Filters" expanded="false">
            <VBox spacing="10">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>

                <!-- Year filter -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Min. Registration Year:" minWidth="170"/>
                    <TextField fx:id="minYearField"
                               promptText="e.g. 20"
                               text="20"
                               prefWidth="60"/>
                    <Label text="(enter 2-digit code; students registered before this year are hidden)"/>
                    <javafx.scene.layout.Region HBox.hgrow="ALWAYS"/>
                    <Button text="Clear Filters" onAction="#onClearFilters" styleClass="secondary-button"/>
                </HBox>

                <!-- Faculty filter -->
                <HBox spacing="10" alignment="TOP_LEFT">
                    <Label text="Faculty:" minWidth="70"/>
                    <FlowPane fx:id="facultyFilterPane" hgap="10" vgap="6" prefWrapLength="700"/>
                </HBox>

                <!-- Major filter -->
                <HBox spacing="10" alignment="TOP_LEFT">
                    <Label text="Major:" minWidth="70"/>
                    <FlowPane fx:id="majorFilterPane" hgap="10" vgap="6" prefWrapLength="700"/>
                </HBox>

            </VBox>
        </TitledPane>

        <!-- ── Groups bar ────────────────────────────────────────────────── -->
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="Group:" minWidth="50"/>
            <ComboBox fx:id="groupComboBox" promptText="All contacts" prefWidth="160"/>
            <Button text="+ New Group" onAction="#onCreateGroup"/>
            <Button text="Add to Group" onAction="#onAddToGroup"/>
            <Button text="Remove from Group" onAction="#onRemoveFromGroup"/>
            <Button text="Delete Group" onAction="#onDeleteGroup" styleClass="danger-button"/>
        </HBox>

        <!-- ── Row 2: count + bulk-select actions ───────────────────────── -->
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label fx:id="contactCountLabel" text="0 contacts"/>
            <javafx.scene.layout.Region HBox.hgrow="ALWAYS"/>
            <Button text="Select All"       onAction="#onSelectAll"/>
            <Button text="Deselect All"     onAction="#onDeselectAll"/>
            <Button text="Send to Selected →"
                    styleClass="primary-button"
                    onAction="#onSendToSelected"/>
        </HBox>

        <!-- ── Contact table ────────────────────────────────────────────── -->
        <TableView fx:id="contactTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="selectColumn"   text=""          prefWidth="40"/>
                <TableColumn fx:id="nameColumn"     text="Name"      prefWidth="180"/>
                <TableColumn fx:id="emailColumn"    text="Email"     prefWidth="220"/>
                <TableColumn fx:id="companyColumn"  text="Company"   prefWidth="160"/>
                <TableColumn fx:id="jobTitleColumn" text="Job Title" prefWidth="150"/>
                <TableColumn fx:id="unsubColumn" text="Status" prefWidth="100"/>
            </columns>
            <placeholder>
                <Label text="No contacts loaded. Click Refresh to fetch from Outlook."/>
            </placeholder>
        </TableView>

        <!-- ── Bottom status bar ────────────────────────────────────────── -->
        <Label fx:id="statusLabel" text="">
            <VBox.margin>
                <Insets bottom="6"/>
            </VBox.margin>
        </Label>

        </VBox>

        <!-- Loading overlay: shown while contacts are being fetched -->
        <VBox fx:id="loadingOverlay"
              alignment="CENTER"
              spacing="12"
              visible="false"
              managed="false"
              style="-fx-background-color: rgba(255,255,255,0.75);">
            <ProgressIndicator fx:id="loadingSpinner" prefWidth="60" prefHeight="60"/>
            <Label fx:id="loadingLabel" text="Loading contacts…" style="-fx-font-size: 14px;"/>
        </VBox>

    </StackPane>
</AnchorPane>
