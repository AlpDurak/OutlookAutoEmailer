<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.outlookautoemailier.ui.ContactListController">

    <VBox AnchorPane.topAnchor="0"
          AnchorPane.rightAnchor="0"
          AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0"
          spacing="10">

        <padding>
            <Insets top="20" right="20" bottom="10" left="20"/>
        </padding>

        <!-- ── Row 1: title + search + refresh ──────────────────────────── -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Contacts" styleClass="page-title" HBox.hgrow="NEVER"/>
            <javafx.scene.layout.Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="searchField"
                       promptText="Search contacts..."
                       prefWidth="200"/>
            <Button text="Refresh" onAction="#onRefresh"/>
        </HBox>

        <!-- ── Row 2: count + bulk-select actions ───────────────────────── -->
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label fx:id="contactCountLabel" text="0 contacts"/>
            <javafx.scene.layout.Region HBox.hgrow="ALWAYS"/>
            <Button text="Select All"       onAction="#onSelectAll"/>
            <Button text="Deselect All"     onAction="#onDeselectAll"/>
            <Button text="Send to Selected →"
                    styleClass="primary-button"
                    onAction="#onSendToSelected"/>
        </HBox>

        <!-- ── Contact table ────────────────────────────────────────────── -->
        <TableView fx:id="contactTable" VBox.vgrow="ALWAYS">
            <columns>
                <!-- CheckBox selection column — cell factory wired in controller -->
                <TableColumn fx:id="selectColumn"   text=""          prefWidth="40"/>
                <TableColumn fx:id="nameColumn"     text="Name"      prefWidth="180"/>
                <TableColumn fx:id="emailColumn"    text="Email"     prefWidth="220"/>
                <TableColumn fx:id="companyColumn"  text="Company"   prefWidth="160"/>
                <TableColumn fx:id="jobTitleColumn" text="Job Title" prefWidth="150"/>
            </columns>
            <placeholder>
                <Label text="No contacts loaded. Click Refresh to fetch from Outlook."/>
            </placeholder>
        </TableView>

        <!-- ── Bottom status bar ────────────────────────────────────────── -->
        <Label fx:id="statusLabel" text="">
            <VBox.margin>
                <Insets bottom="6"/>
            </VBox.margin>
        </Label>

    </VBox>
</AnchorPane>
