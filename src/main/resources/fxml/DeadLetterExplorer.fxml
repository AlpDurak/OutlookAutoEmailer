<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox spacing="0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.outlookautoemailier.ui.DeadLetterExplorerController">

    <padding>
        <Insets top="28" right="28" bottom="24" left="28"/>
    </padding>

    <!-- ── Page heading ─────────────────────────────────────────────────── -->
    <VBox spacing="4">
        <Label text="Dead-Letter Queue" styleClass="page-title"/>
        <Label text="Emails that failed all retry attempts and require manual action."
               styleClass="help-label"/>
    </VBox>

    <Region prefHeight="20"/>
    <Separator/>
    <Region prefHeight="20"/>

    <!-- ── Stat summary bar ─────────────────────────────────────────────── -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <VBox styleClass="stat-card" alignment="CENTER" minWidth="140">
            <Label fx:id="totalDeadLabel" text="0" styleClass="stat-count"
                   style="-fx-text-fill:#dc2626;"/>
            <Label text="Dead-Lettered" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card,dl-top-reason-card" alignment="CENTER" minWidth="220">
            <Label fx:id="topReasonLabel" text="--" styleClass="dl-top-reason-value"/>
            <Label text="Most Common Failure" styleClass="stat-label"/>
        </VBox>
    </HBox>

    <Region prefHeight="16"/>

    <!-- ── Filter controls ──────────────────────────────────────────────── -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField"
                   promptText="Search by email or domain…"
                   prefWidth="260"/>
        <ComboBox fx:id="reasonFilter" promptText="All Failure Reasons" prefWidth="220"/>
        <Button text="Clear Filters" onAction="#onClearFilters" styleClass="secondary-button">
            <graphic><FontIcon iconLiteral="fas-times" iconSize="14"/></graphic>
        </Button>
    </HBox>

    <Region prefHeight="12"/>

    <!-- ── Job table ────────────────────────────────────────────────────── -->
    <TableView fx:id="deadLetterTable" VBox.vgrow="ALWAYS" prefHeight="300">
        <columns>
            <TableColumn fx:id="recipientColumn"     text="Recipient"      prefWidth="200"/>
            <TableColumn fx:id="domainColumn"        text="Domain"         prefWidth="130"/>
            <TableColumn fx:id="subjectColumn"       text="Subject"        prefWidth="180"/>
            <TableColumn fx:id="failureReasonColumn" text="Failure Reason" prefWidth="200"/>
            <TableColumn fx:id="attemptsColumn"      text="Attempts"       prefWidth="70"/>
            <TableColumn fx:id="timestampColumn"     text="Timestamp"      prefWidth="140"/>
        </columns>
        <placeholder>
            <Label text="No dead-letter jobs found." styleClass="help-label"/>
        </placeholder>
    </TableView>

    <Region prefHeight="16"/>

    <!-- ── Failure breakdown ────────────────────────────────────────────── -->
    <Label text="FAILURE BREAKDOWN" styleClass="section-header"/>
    <Region prefHeight="8"/>
    <VBox fx:id="failureBreakdownBox" spacing="4">
        <padding>
            <Insets left="4"/>
        </padding>
    </VBox>

    <Separator>
        <VBox.margin><Insets top="16" bottom="16"/></VBox.margin>
    </Separator>

    <!-- ── Action buttons ───────────────────────────────────────────────── -->
    <HBox spacing="8" alignment="CENTER_LEFT">
        <Button text="Retry Selected" styleClass="primary-button" onAction="#onRetrySelected">
            <graphic><FontIcon iconLiteral="fas-redo" iconSize="14"/></graphic>
        </Button>
        <Button text="Retry All Visible" onAction="#onRetryAll">
            <graphic><FontIcon iconLiteral="fas-redo" iconSize="14"/></graphic>
        </Button>
        <Button text="Export CSV" onAction="#onExportCsv">
            <graphic><FontIcon iconLiteral="fas-download" iconSize="14"/></graphic>
        </Button>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Delete Selected" styleClass="danger-button" onAction="#onDeleteSelected">
            <graphic><FontIcon iconLiteral="fas-trash-alt" iconSize="14"/></graphic>
        </Button>
    </HBox>

</VBox>
