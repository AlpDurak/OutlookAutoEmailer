# OutlookAutoEmailer — sensitive configuration
# Copy this file to ~/.outlookautoemailier/.env and fill in your values.
# Lines starting with # are comments.

# imgbb.com API key — for hosting inline email images
IMGBB_API_KEY=your_imgbb_api_key_here

# Google OAuth2 credentials (from console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Supabase service role key (from Project Settings -> API -> service_role)
# KEEP THIS SECRET — never commit or share this value.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
